{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "FileSettings": {
    "FolderName": "Images",
    "MaxSize": 2097152,
    "AllowedExtensions": [ ".png", ".jpg", ".jpeg", ".webp" ],
    "AllowedContentTypes": [ "image/png", "image/jpeg", "image/webp" ]
  },
  "AllowedHosts": "*"
}
