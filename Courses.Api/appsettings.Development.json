{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowHosts": "*",
  "ConnectionStrings": {
    "Default": "Server = .; Database = Courses; Trusted_Connection = True; TrustServerCertificate= True"
  },
  "JWT": {
    "audience": "MyClients",
    "issuer": "https://localhost:7114",
    "expires": 1,
    "Key": "a-string-secret-at-least-256-bits-long"
  },
  "BasePictureUrl": "https://localhost:7114",
  "FileSitteng": {
    "MaxSize": 2097152,
    "Allowed_Extentions": [ ".png", ".jpg", ".jpeg" ]
  },
  "FrontEndUrl": "http://localhost:4200",
  "AllowCORS": [
    "http://localhost:4200",
    "https://localhost:4200"
  ]
}
